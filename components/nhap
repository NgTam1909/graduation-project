'use client'

import { useEffect, useState } from "react"
import { ArrowRight, Bell, HelpCircle, Search, User } from "lucide-react"
import Image from "next/image"
import { useRouter } from "next/navigation"
import { Button } from "@/components/ui/button"
import {
    DropdownMenu,
    DropdownMenuContent,
    DropdownMenuItem,
    DropdownMenuLabel,
    DropdownMenuSeparator,
    DropdownMenuTrigger,
} from "@/components/ui/dropdown-menu"
import { Input } from "@/components/ui/input"
import { Separator } from "@/components/ui/separator"
import { POST_METHOD } from "@/lib/req"
import { cn } from "@/lib/utils"
import { useUpdateProfile } from "@/hooks/use-update-profile"
import { useNotification } from "@/hooks/use-notification"
import UpdateProfileDialog from "@/components/updateProfile"

type NavMenuProps = {
    onToggleSidebarAction?: () => void
    className?: string
}

export default function NavMenu({ onToggleSidebarAction, className }: NavMenuProps) {
    const router = useRouter()
    const [mounted, setMounted] = useState(false)
    const [accountOpen, setAccountOpen] = useState(false)

    const {
        notifications,
        logsLoading,
        logsError,
        loadNotifications,
    } = useNotification()

    const {
        profileLoading,
        profileSaving,
        profileError,
        profileSuccess,
        profileEmail,
        profileName,
        positionValue,
        setPositionValue,
        skillsValue,
        setSkillsValue,
        handleSaveProfile,
    } = useUpdateProfile(accountOpen)

    useEffect(() => {
        setMounted(true)
    }, [])

    const handleLogout = async () => {
        await POST_METHOD("/api/auth/logout", {})
        localStorage.removeItem("accessToken")
        window.location.href = "/login"
    }

    return (
        <nav className={cn("w-full border-b bg-background", className)}>
            {/* giữ nguyên UI như bạn */}
            <div className="flex w-full items-center justify-between px-4 py-2">
                {/* ... giữ nguyên */}
                <div className="flex items-center gap-2">
                    {mounted && (
                        <DropdownMenu onOpenChange={(o) => o && loadNotifications()}>
                            <DropdownMenuTrigger asChild>
                                <Button variant="ghost" size="icon">
                                    <Bell size={20} />
                                </Button>
                            </DropdownMenuTrigger>

                            <DropdownMenuContent className="w-96">
                                {logsLoading && "Đang tải..."}
                                {logsError && logsError}
                                {notifications.map((n) => (
                                    <div key={n.id}>{n.action}</div>
                                ))}
                            </DropdownMenuContent>
                        </DropdownMenu>
                    )}
                </div>
            </div>

            <UpdateProfileDialog
                open={accountOpen}
                onOpenChange={setAccountOpen}
                profileLoading={profileLoading}
                profileSaving={profileSaving}
                profileName={profileName}
                profileEmail={profileEmail}
                positionValue={positionValue}
                setPositionValue={setPositionValue}
                skillsValue={skillsValue}
                setSkillsValue={setSkillsValue}
                profileError={profileError}
                profileSuccess={profileSuccess}
                onSave={() => void handleSaveProfile()}
            />
        </nav>
    )
}
